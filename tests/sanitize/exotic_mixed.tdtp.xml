<?xml version="1.0" encoding="UTF-8"?>
<!--
  Test: Mixed exotic characters — European diacritics, symbols, Unicode
  Covers: European languages, currency symbols, mathematical notation, etc.

  Import with full sanitization:
    tdtpcli --import tests/sanitize/exotic_mixed.tdtp.xml --translit --clear --config config.yaml

  Expected renames (translit+clear):
    "id"             → id  (unchanged)
    "Österreich"     → Osterreich
    "Ñoño"          → Nono
    "Cena (zł)"     → Cena_zl
    "Precio %"       → Precio_pct
    "Коэф. роста"   → Koef_rosta
    "Заказ №12"     → Zakaz_no12   (note: this is a field *name*, not value)
    "~disabled"      → not_disabled
    "a&b total"      → a_and_b_total
    "cost@unit"      → cost_at_unit
    "flag*"          → flag_star
    "1st_place"      → _1st_place   (digit prefix)
    "___"            → _field        (all-underscore collapses to empty → _field)
-->
