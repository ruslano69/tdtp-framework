# Copy to .env and fill in before running docker-compose.prod.yml

# Redis password (same for both instances)
REDIS_PASSWORD=change-me-strong-redis-password

# xZMercury HMAC secret — min 32 chars, keep secret
MERCURY_SERVER_SECRET=change-me-32-chars-minimum-here!!

# License key issued by tdtp-certify issue-license
TDTPCA_LICENSE_KEY=TDTP-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
